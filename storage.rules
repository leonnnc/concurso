// ═══════════════════════════════════════════════════════
//  storage.rules — Reglas de seguridad Firebase Storage
//  Pega esto en Firebase Console → Storage → Reglas
// ═══════════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── FOTOS DEL CONCURSO ──
    match /photos/{userId}/{fileName} {

      // Lectura pública (URLs de descarga)
      allow read: if true;

      // Subida: solo el usuario autenticado puede subir a su carpeta
      // Límite: 10 MB, solo imágenes
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Eliminar: solo el autor
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
